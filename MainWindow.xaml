<Window
    x:Class="VideoCutCS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="MainRoot"
          AllowDrop="True"
          DragOver="MainRoot_DragOver"
          Drop="MainRoot_Drop"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Left" Invoked="Shortcut_SeekBack5s"/>
            <KeyboardAccelerator Key="Right" Invoked="Shortcut_SeekForward5s"/>
            <KeyboardAccelerator Key="Left" Modifiers="Control" Invoked="Shortcut_SeekBack1s"/>
            <KeyboardAccelerator Key="Right" Modifiers="Control" Invoked="Shortcut_SeekForward1s"/>
            <KeyboardAccelerator Key="I" Invoked="Shortcut_SetStart"/>
            <KeyboardAccelerator Key="F" Invoked="Shortcut_SetEnd"/>
            <KeyboardAccelerator Key="Space" Invoked="Shortcut_PlayPause"/>
            <KeyboardAccelerator Key="S" Invoked="Shortcut_Snapshot"/>
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="ファイル(F)">
                <MenuFlyoutItem Text="開く(O)..." Click="MenuOpen_Click" Icon="OpenFile"/>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="終了(X)" Click="MenuExit_Click" Icon="Cancel"/>
            </MenuBarItem>
        </MenuBar>

        <!-- 動画プレイヤーとガイド表示 -->
        <MediaPlayerElement x:Name="Player"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AreTransportControlsEnabled="False"
                            AutoPlay="False"
                            PreviewKeyDown="Player_PreviewKeyDown"
                            PointerWheelChanged="Player_PointerWheelChanged"/>

        <StackPanel x:Name="GuidePanel"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10" IsHitTestVisible="False">
            <TextBlock Text="動画をドロップ または [ファイル] > [開く]"
                       FontSize="24"
                       HorizontalAlignment="Center"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- 操作パネル -->
        <StackPanel Grid.Row="2"
                    Orientation="Vertical"
                    Padding="20"
                    Spacing="10"
                    Background="#202020">

            <!-- タイムラインと時間表示 -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 自作タイムライン -->
                <Grid x:Name="TimelineArea"
                      Grid.Column="0"
                      Height="30"
                      VerticalAlignment="Center"
                      Margin="0,0,15,0"
                      Background="Transparent"
                      PointerPressed="Timeline_PointerPressed"
                      PointerMoved="Timeline_PointerMoved"
                      PointerReleased="Timeline_PointerReleased"
                      PointerExited="Timeline_PointerExited"
                      SizeChanged="Timeline_SizeChanged">

                    <!-- 背景バー -->
                    <Rectangle x:Name="TimelineBackground"
                               Fill="#606060"
                               Height="6"
                               RadiusX="3" RadiusY="3"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Stretch"
                               IsHitTestVisible="False"
                               Margin="0"/>

                    <!-- 選択範囲（黄色） -->
                    <Rectangle x:Name="SelectionRect"
                               Fill="#FFD60A"
                               Height="6"
                               RadiusX="3" RadiusY="3"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Visibility="Collapsed"
                               IsHitTestVisible="False"/>

                    <!-- 再生ヘッド -->
                    <Grid x:Name="Playhead"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Stretch"
                          Width="20"
                          IsHitTestVisible="False">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="PlayheadTransform" X="0"/>
                        </Grid.RenderTransform>
                        <Rectangle Width="2" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,5,0,5"/>
                        <Ellipse Width="14" Height="14" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- ★自作ツールチップ (標準ToolTipの代わりに配置) -->
                    <!-- MarginのTopをマイナスにしてタイムラインの上に表示 -->
                    <Grid x:Name="HoverTooltip"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Left"
                          Visibility="Collapsed"
                          IsHitTestVisible="False"
                          Margin="0,-45,0,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="HoverTooltipTransform" X="0"/>
                        </Grid.RenderTransform>

                        <!-- 吹き出し本体 -->
                        <Border Background="#CC000000" CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="HoverTooltipText" 
                                       Text="00:00:00" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <!-- 下向きの三角（吹き出しのしっぽ） -->
                        <Polygon Points="0,0 6,6 12,0" 
                                 Fill="#CC000000" 
                                 HorizontalAlignment="Center" 
                                 VerticalAlignment="Bottom" 
                                 Margin="0,0,0,-6"/>
                    </Grid>

                </Grid>

                <!-- 時間表示テキスト -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                    <TextBox x:Name="TimeBox"
                             Text="00:00:00"
                             Width="100"
                             FontSize="14"
                             TextAlignment="Center"
                             VerticalAlignment="Center"
                             KeyDown="TimeBox_KeyDown"
                             TextChanged="TimeBox_TextChanged"
                             GotFocus="TimeBox_GotFocus"
                             LostFocus="TimeBox_LostFocus"/>
                    <TextBlock Text="/" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DurationText"
                               Text="00:00:00"
                               FontSize="14"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- カット範囲設定（開始/終了） -->
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <TextBlock Text="開始:" FontSize="16" Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBox x:Name="TextStartTime" Text="00:00:00.000" Width="120" FontSize="16" Background="Transparent" BorderThickness="0,0,0,1" Foreground="White" GotFocus="StartTime_GotFocus" LostFocus="StartTime_LostFocus" KeyDown="StartTime_KeyDown"/>

                <TextBlock Text="～" FontSize="16" Foreground="LightGray" VerticalAlignment="Center"/>

                <TextBlock Text="終了:" FontSize="16" Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBox x:Name="TextEndTime" Text="(未設定)" Width="120" FontSize="16" Background="Transparent" BorderThickness="0,0,0,1" Foreground="White" GotFocus="EndTime_GotFocus" LostFocus="EndTime_LostFocus" KeyDown="EndTime_KeyDown"/>

                <TextBlock x:Name="TextDuration" Text="(長さ: 00:00:00.000)" FontSize="16" Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- 操作ボタン群 -->
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                <Button x:Name="BtnPlayPause" Click="BtnPlayPause_Click" Width="60" Height="40" ToolTipService.ToolTip="再生/一時停止 (Space)">
                    <SymbolIcon x:Name="IconPlayPause" Symbol="Play"/>
                </Button>
                <Button x:Name="BtnSnapshot" Click="BtnSnapshot_Click" Width="60" Height="40" ToolTipService.ToolTip="現在のフレームを保存 (S)">
                    <SymbolIcon Symbol="Camera"/>
                </Button>

                <Border Width="20"/>

                <Button x:Name="BtnSetStart" Content="[ 開始位置 (I) ]" Click="BtnSetStart_Click" Width="120"/>
                <Button x:Name="BtnSetEnd"   Content="[ 終了位置 (F) ]" Click="BtnSetEnd_Click"   Width="120"/>

                <Border Width="20"/>

                <Button x:Name="BtnCut"
                        Content="✂ カット実行"
                        Click="BtnCut_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        Width="120"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="準備完了" HorizontalAlignment="Center" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>